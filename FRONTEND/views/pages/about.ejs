<% layout('layouts/boilerplate') %>
<div class="container" style="padding: 4rem 1rem; max-width: 800px; margin: 0 auto; min-height: 60vh;">
    <h1 style="color: var(--text-primary); margin-bottom: 1.5rem; font-size: 2.5rem;">About YatraAI</h1>
    <div style="background: var(--bg-card); padding: 2rem; border-radius: var(--radius); border: 1px solid var(--border); line-height: 1.8;">
        <p style="margin-bottom: 1rem; color: var(--text-secondary);">Welcome to YatraAI, your intelligent companion for navigating the vibrant landscapes and rich heritage of India. We combine real-world hotel data with cutting-edge Artificial Intelligence to provide you with seamless travel planning.</p>
        <p style="margin-bottom: 1rem; color: var(--text-secondary);">Founded in 2025, our mission is to eliminate the stress of travel planning. With our specialized AI Agents, you can ask for bespoke itineraries, local food recommendations, and hidden gems—all while booking 100% verified premium stays.</p>
        <p style="color: var(--text-secondary);">Embark on your next adventure with confidence. The journey begins here.</p>
    </div>
</div>
