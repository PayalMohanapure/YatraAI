<% layout('layouts/boilerplate') %>

<div class="form-page">
  <div class="form-card">
    <h1><i class="fa-solid fa-plus-circle"></i> Add New Hotel</h1>
    <p class="form-subtitle">Add a new Indian hotel to the WanderlustAI collection</p>

    <form action="/listings" method="POST" class="listing-form" enctype="multipart/form-data">

      <div class="form-group">
        <label for="title"><i class="fa-solid fa-hotel"></i> Hotel Name</label>
        <input type="text" id="title" name="listing[title]" placeholder="e.g. Taj Lake Palace" required />
      </div>

      <div class="form-group">
        <label for="description"><i class="fa-solid fa-align-left"></i> Description</label>
        <textarea id="description" name="listing[description]" rows="4" placeholder="Describe the hotel..."></textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="location"><i class="fa-solid fa-location-dot"></i> City</label>
          <input type="text" id="location" name="listing[location]" placeholder="e.g. Udaipur" required />
        </div>
        <div class="form-group">
          <label for="country"><i class="fa-solid fa-flag"></i> Country</label>
          <input type="text" id="country" name="listing[country]" value="India" required />
        </div>
      </div>

      <div class="form-group">
        <label for="imageUrl"><i class="fa-solid fa-image"></i> Upload Image</label>
        <input type="file" id="imageUrl" name="listing[image]" accept="image/*" />
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="price"><i class="fa-solid fa-indian-rupee-sign"></i> Price per Night (₹)</label>
          <input type="number" id="price" name="listing[price]" placeholder="e.g. 5000" min="0" required />
        </div>
        <div class="form-group">
          <label for="starRating"><i class="fa-solid fa-star"></i> Star Rating</label>
          <select id="starRating" name="listing[starRating]">
            <option value="3">3 Stars</option>
            <option value="4">4 Stars</option>
            <option value="5" selected>5 Stars</option>
          </select>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="longitude"><i class="fa-solid fa-map-pin"></i> Longitude</label>
          <input type="number" id="longitude" name="listing[geometry][coordinates][0]" placeholder="e.g. 73.68" step="any" required />
        </div>
        <div class="form-group">
          <label for="latitude"><i class="fa-solid fa-map-pin"></i> Latitude</label>
          <input type="number" id="latitude" name="listing[geometry][coordinates][1]" placeholder="e.g. 24.57" step="any" required />
        </div>
      </div>

      <!-- Hidden required fields for GeoJSON -->
      <input type="hidden" name="listing[geometry][type]" value="Point" />

      <div class="form-actions">
        <button type="submit" class="btn-submit"><i class="fa-solid fa-paper-plane"></i> Add Hotel</button>
        <a href="/listings" class="btn-cancel">Cancel</a>
      </div>
    </form>
  </div>
</div>
