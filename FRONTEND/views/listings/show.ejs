<% layout('layouts/boilerplate') %>

<div class="show-container">

  <!-- ─── Hotel Header ─── -->
  <div class="show-hero">
    <img
      src="<%= listing.image.url %>"
      alt="<%= listing.title %>"
      class="show-hero-img"
      onerror="this.src='https://images.unsplash.com/photo-1566073771259-6a8506099945?w=800'"
    />
    <div class="show-hero-overlay">
      <div class="show-hero-content">
        <div class="show-stars">
          <% for(let i = 0; i < listing.starRating; i++) { %>
            <i class="fa-solid fa-star"></i>
          <% } %>
        </div>
        <h1 class="show-title"><%= listing.title %></h1>
        <p class="show-location"><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></p>
      </div>
    </div>
  </div>

  <!-- ─── Main Content ─── -->
  <div class="show-body">

    <!-- Left Column -->
    <div class="show-left">

      <!-- About -->
      <div class="show-card">
        <h2><i class="fa-solid fa-hotel"></i> About this property</h2>
        <p class="show-description"><%= listing.description %></p>
        <div class="show-meta-grid">
          <div class="meta-item">
            <i class="fa-solid fa-star"></i>
            <div><strong><%= listing.rating %> / 5</strong><p>Guest Rating</p></div>
          </div>
          <div class="meta-item">
            <i class="fa-solid fa-comments"></i>
            <div><strong><%= listing.reviewCount %></strong><p>Reviews</p></div>
          </div>
          <div class="meta-item">
            <i class="fa-solid fa-crown"></i>
            <div><strong><%= listing.starRating %> Star</strong><p>Category</p></div>
          </div>
          <div class="meta-item">
            <i class="fa-solid fa-indian-rupee-sign"></i>
            <div><strong>₹<%= listing.price.toLocaleString("en-IN") %></strong><p>Per Night</p></div>
          </div>
        </div>
      </div>

      <!-- Map -->
      <div class="show-card">
        <h2><i class="fa-solid fa-map-location-dot"></i> Location on Map</h2>
        <div id="map"></div>
      </div>

      <!-- Actions -->
      <div class="show-actions">
        <% if(currentUser && listing.owner && listing.owner._id.equals(currentUser._id)) { %>
            <a href="/listings/<%= listing._id %>/edit" class="btn-edit">
              <i class="fa-solid fa-pen"></i> Edit Hotel
            </a>
            <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
              <button type="submit" class="btn-delete" onclick="return confirm('Delete this hotel?')">
                <i class="fa-solid fa-trash"></i> Delete
              </button>
            </form>
        <% } %>
        <a href="/listings" class="btn-back">
          <i class="fa-solid fa-arrow-left"></i> All Hotels
        </a>
      </div>
      </div>

      <hr style="margin: 2rem 0; border: 0; border-top: 1px solid var(--border);">

      <!-- Reviews Section -->
      <div class="reviews-section">
        <h3><i class="fa-solid fa-star"></i> Reviews (<%= listing.reviews.length %>)</h3>
        
        <% if(currentUser) { %>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" class="listing-form" style="margin-bottom: 2rem; background: var(--bg-card); padding: 1.5rem; border-radius: var(--radius); border: 1px solid var(--border);">
            <div class="form-group">
                <label for="rating">Rating</label>
                <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range" style="width: 100%;">
            </div>
            <div class="form-group">
                <label for="comment">Comment</label>
                <textarea id="comment" name="review[comment]" rows="3" required style="width: 100%; padding: 0.5rem; border-radius: 8px; border: 1px solid var(--border);"></textarea>
            </div>
            <button class="btn-submit" type="submit" style="padding: 0.5rem 1rem;">Submit Review</button>
        </form>
        <% } else { %>
            <p><a href="/login" style="color: var(--accent); font-weight: bold;">Log in</a> to leave a review.</p>
        <% } %>

        <div class="reviews-list">
            <% for(let review of listing.reviews) { %>
                <div class="review-card" style="background: var(--bg-card2); padding: 1rem; border-radius: var(--radius-sm); margin-bottom: 1rem; border: 1px solid var(--border);">
                    <div style="display: flex; justify-content: space-between; align-items: start;">
                        <div>
                            <strong style="color: var(--accent);"><%= review.author.username %></strong>
                            <p class="show-stars" style="margin: 0.2rem 0;">
                                <% for(let i=0; i<review.rating; i++) { %>★<% } %>
                            </p>
                            <p style="margin-top: 0.5rem; font-size: 0.95rem; color: var(--text-secondary);"><%= review.comment %></p>
                        </div>
                        <% if(currentUser && review.author._id.equals(currentUser._id)) { %>
                            <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                                <button type="submit" class="btn-delete" style="padding: 0.3rem 0.6rem; font-size: 0.8rem;">Delete</button>
                            </form>
                        <% } %>
                    </div>
                </div>
            <% } %>
        </div>
      </div>
    </div>

    <!-- Right Column: Booking Card -->
    <div class="show-right">
      <div class="booking-card">
        <h3><i class="fa-solid fa-calendar-check"></i> Book Your Stay</h3>
        <p class="booking-price">₹<%= listing.price.toLocaleString("en-IN") %> <span>/night</span></p>

        <form action="/listings/<%= listing._id %>/book" method="POST" class="booking-form">
          <div class="form-group">
            <label><i class="fa-solid fa-calendar"></i> Check-In</label>
            <input type="date" name="booking[checkIn]" id="checkIn" required />
          </div>
          <div class="form-group">
            <label><i class="fa-solid fa-calendar"></i> Check-Out</label>
            <input type="date" name="booking[checkOut]" id="checkOut" required />
          </div>
          <div class="form-group">
            <label><i class="fa-solid fa-users"></i> Guests</label>
            <select name="booking[guests]">
              <option value="1">1 Guest</option>
              <option value="2" selected>2 Guests</option>
              <option value="3">3 Guests</option>
              <option value="4">4 Guests</option>
            </select>
          </div>
          <div class="price-breakdown" id="priceBreakdown" style="display:none;">
            <div class="price-row">
              <span>₹<%= listing.price.toLocaleString("en-IN") %> × <span id="nights">0</span> nights</span>
              <span id="totalPrice">₹0</span>
            </div>
          </div>
          <button type="submit" class="btn-book">
            <i class="fa-solid fa-bolt"></i> Book Now
          </button>
        </form>
    </div>
  </div>



</div>

<!-- Pass coordinates and hotel data to JS -->
<script>
  const listingCoords = <%- JSON.stringify(listing.geometry.coordinates) %>;
  const listingTitle  = "<%= listing.title %>";
  const listingPrice  = <%- listing.price %>;
  const listingId     = "<%= listing._id %>";
</script>
<script src="/js/map.js"></script>
<script src="/js/booking.js"></script>
